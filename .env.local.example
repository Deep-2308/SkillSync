# ---------------------------------------------------------------------------
# SkillSync environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit `.env.local`.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# MongoDB connection string (Atlas or self-hosted). Include the database name.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/skillsync?retryWrites=true&w=majority"

# --- NextAuth (Auth.js v5) --------------------------------------------------
# Secret used to sign/encrypt JWTs and cookies. Generate with: `openssl rand -base64 32`
NEXTAUTH_SECRET="replace-with-a-32-byte-random-string"

# Canonical URL of the deployment. Locally this is http://localhost:3000.
# On Vercel this is set automatically, but keep it here for local + preview parity.
NEXTAUTH_URL="http://localhost:3000"

# --- Google OAuth provider --------------------------------------------------
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# --- Public (client-exposed) ------------------------------------------------
# Anything prefixed with NEXT_PUBLIC_ is inlined into the browser bundle.
# Never put secrets here. Used for building absolute URLs in the client.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
